# Copy to keystore.properties (gitignored) for local signed release builds.
# Paths are relative to the repository root.
#
# Or use env only: RELEASE_KEYSTORE_FILE, RELEASE_KEY_ALIAS, and either
# RELEASE_KEYSTORE_PASSWORD or RELEASE_KEY_PASSWORD (the latter can stand in for both).
storeFile=upload-keystore.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=upload
keyPassword=YOUR_KEY_PASSWORD_OR_SAME_AS_STORE
